// PIC24FJ128GA010 Configuration Bit Settings
// CONFIG2
#pragma config POSCMOD = XT 
#pragma config OSCIOFNC = ON 
#pragma config FCKSM = CSDCMD 
#pragma config FNOSC = PRI 
#pragma config IESO = ON 
// CONFIG1
#pragma config WDTPS = PS32768 
#pragma config FWPSA = PR128 
#pragma config WINDIS = ON 
#pragma config FWDTEN = OFF 
#pragma config ICS = PGx2 
#pragma config GWRP = OFF 
#pragma config GCP = OFF 
#pragma config JTAGEN = OFF 

// Definicja taktowania (wymagana dla __delay32)
#define FCY 4000000UL 

#include <xc.h>
#include <libpic30.h>
#include <stdbool.h>
#include <stdint.h>
#include "buttons.h"
#include "adc.h"

// Stany alarmu (usunięto stan WYLACZONY, bo wracamy prosto do NORMALNY)
typedef enum {
    STAN_NORMALNY,
    STAN_MRUGANIE,
    STAN_CIAGLY
} StanAlarmu;

int main(void) {
    // ------------------------------------------------
    // KONFIGURACJA SPRZĘTU
    // ------------------------------------------------
    AD1PCFG = 0xFFFF; // Ustawienie pinów jako cyfrowe I/O (dla LED)
    TRISA = 0x0000;   // PORTA (diody LED) jako wyjścia
    LATA = 0x0000;    // Zgaszenie wszystkich diod na start
    
    ADC_SetConfiguration(ADC_CONFIGURATION_DEFAULT);
    ADC_ChannelEnable(ADC_CHANNEL_POTENTIOMETER);
    
    StanAlarmu obecnyStan = STAN_NORMALNY;
    unsigned int wartoscPotencjometru = 0;
    int licznikCzasu = 0; 
    
    // ------------------------------------------------
    // GŁÓWNA PĘTLA PROGRAMU
    // ------------------------------------------------
    while (1) {
        wartoscPotencjometru = ADC_Read10bit(ADC_CHANNEL_POTENTIOMETER);
        if (wartoscPotencjometru == 0xFFFF) {
            continue; 
        }
        
        // --- LOGIKA ALARMU ---
        
        // 1. Jeśli jest normalnie i przekroczymy 50% (512) -> odpalamy alarm
        if (obecnyStan == STAN_NORMALNY) {
            if (wartoscPotencjometru >= 512) {
                obecnyStan = STAN_MRUGANIE;
                licznikCzasu = 0;
            }
        } 
        // 2. Jeśli alarm trwa (mruga lub świeci ciągle)
        else if (obecnyStan == STAN_MRUGANIE || obecnyStan == STAN_CIAGLY) {
            
            // PRÓBA WYŁĄCZENIA: Działa TYLKO, gdy suwak < 50% ORAZ wciśnięto S3
            if (wartoscPotencjometru < 512 && BUTTON_IsPressed(BUTTON_S3) == true) {
                obecnyStan = STAN_NORMALNY;
                LATA = 0x0000; // Zgaś diody
            }
            
            // Jeśli alarmu nie wyłączono, realizujemy jego świecenie:
            if (obecnyStan == STAN_MRUGANIE) {
                // Mruganie (co 5 obiegów pętli)
                if ((licznikCzasu / 5) % 2 == 0) {
                    LATA = 0x0001; 
                } else {
                    LATA = 0x0000; 
                }
                
                licznikCzasu++;
                
                // Po 50 obiegach (5 sekundach) przechodzimy w tryb ciągły
                if (licznikCzasu >= 50) {
                    obecnyStan = STAN_CIAGLY;
                }
            } 
            else if (obecnyStan == STAN_CIAGLY) {
                LATA = 0x00FF; // Zapal wszystkie 8 diod
            }
        }
        
        // Baza czasu: 400 000 cykli = 100 milisekund (przy zegarze 4 MHz)
        __delay32(400000); 
    }
    
    return 0;
}
