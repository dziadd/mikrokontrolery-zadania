#include <xc.h>
#include <libpic30.h>
#include <stdbool.h>    
#include <stdint.h>     
#include "buttons.h"
#include "lcd.h" 

// =========================================================
// ZADANIE 1 - PODPROGRAMY LICZNIKÓW
// =========================================================

// Podprogram 1: 8-bitowy licznik binarny w górę (0...255)
int prog1(void) {
    unsigned char count = 0; // Zmienna licznika
    
    LCD_ClearScreen();
    LCD_PutString("P1: BIN W GORE", 14);
    
    // Zabezpieczenie drgań styków - czekamy na puszczenie przycisków
    while(BUTTON_IsPressed(BUTTON_S6) || BUTTON_IsPressed(BUTTON_S3)) { __delay32(10000); }

    while(1) {
        // Sprawdzanie przycisków i ewakuacja (zmiana stanu)
        if (BUTTON_IsPressed(BUTTON_S6)) return 2; // Następny program to 2
        if (BUTTON_IsPressed(BUTTON_S3)) return 6; // Poprzedni program to 6

        LATA = count; // Wystawienie wartości na diody LED
        count++;      // Inkrementacja (po 255 nastąpi naturalne przekręcenie na 0)
        
        __delay32(2000000); // Opóźnienie, aby licznik był widoczny dla oka
    }
}

// Podprogram 2: 8-bitowy licznik binarny w dół (255...0)
int prog2(void) {
    unsigned char count = 255; 
    
    LCD_ClearScreen();
    LCD_PutString("P2: BIN W DOL", 13);
    
    while(BUTTON_IsPressed(BUTTON_S6) || BUTTON_IsPressed(BUTTON_S3)) { __delay32(10000); }

    while(1) {
        if (BUTTON_IsPressed(BUTTON_S6)) return 3;
        if (BUTTON_IsPressed(BUTTON_S3)) return 1;

        LATA = count;
        count--; // Dekrementacja
        
        __delay32(2000000); 
    }
}

// Podprogram 3: 8-bitowy licznik kod Graya w górę
int prog3(void) {
    unsigned char count = 0;
    
    LCD_ClearScreen();
    LCD_PutString("P3: GRAY W GORE", 15);
    
    while(BUTTON_IsPressed(BUTTON_S6) || BUTTON_IsPressed(BUTTON_S3)) { __delay32(10000); }

    while(1) {
        if (BUTTON_IsPressed(BUTTON_S6)) return 4;
        if (BUTTON_IsPressed(BUTTON_S3)) return 2;

        // Konwersja naturalnego kodu binarnego na kod Graya: G = B XOR (B przesunięte o 1 w prawo)
        unsigned char grayValue = count ^ (count >> 1);
        LATA = grayValue;
        
        count++; 
        __delay32(2000000);
    }
}

// Podprogram 4: 8-bitowy licznik kod Graya w dół
int prog4(void) {
    unsigned char count = 255;
    
    LCD_ClearScreen();
    LCD_PutString("P4: GRAY W DOL", 14);
    
    while(BUTTON_IsPressed(BUTTON_S6) || BUTTON_IsPressed(BUTTON_S3)) { __delay32(10000); }

    while(1) {
        if (BUTTON_IsPressed(BUTTON_S6)) return 5;
        if (BUTTON_IsPressed(BUTTON_S3)) return 3;

        unsigned char grayValue = count ^ (count >> 1);
        LATA = grayValue;
        
        count--; 
        __delay32(2000000);
    }
}

// Podprogram 5: 2x4 bitowy licznik w kodzie BCD w górę (0...99)
int prog5(void) {
    // Używamy typu ze znakiem (char zamiast unsigned char), by łatwo sprawdzać przekroczenia
    char tens = 0; // dziesiątki
    char units = 0; // jedności
    
    LCD_ClearScreen();
    LCD_PutString("P5: BCD W GORE", 14);
    
    while(BUTTON_IsPressed(BUTTON_S6) || BUTTON_IsPressed(BUTTON_S3)) { __delay32(10000); }

    while(1) {
        if (BUTTON_IsPressed(BUTTON_S6)) return 6;
        if (BUTTON_IsPressed(BUTTON_S3)) return 4;

        // Składanie dwóch cyfr na jednym porcie: dziesiątki przesuwamy na 4 najstarsze bity
        LATA = (tens << 4) | units;

        units++;
        // Kiedy jedności przekroczą 9, zerujemy je i zwiększamy dziesiątki
        if (units > 9) {
            units = 0;
            tens++;
            if (tens > 9) {
                tens = 0; // Wyzerowanie po dojściu do 99
            }
        }
        __delay32(2000000);
    }
}

// Podprogram 6: 2x4 bitowy licznik w kodzie BCD w dół (99...0)
int prog6(void) {
    char tens = 9;
    char units = 9;
    
    LCD_ClearScreen();
    LCD_PutString("P6: BCD W DOL", 13);
    
    while(BUTTON_IsPressed(BUTTON_S6) || BUTTON_IsPressed(BUTTON_S3)) { __delay32(10000); }

    while(1) {
        if (BUTTON_IsPressed(BUTTON_S6)) return 1; // Zapętlenie w górę do programu 1
        if (BUTTON_IsPressed(BUTTON_S3)) return 5;

        LATA = (tens << 4) | units;

        units--;
        // Jeśli jedności spadną poniżej 0, ustawiamy je na 9 i odejmujemy dziesiątki
        if (units < 0) {
            units = 9;
            tens--;
            if (tens < 0) {
                tens = 9; // Reset do 99 po przejściu poniżej zera
            }
        }
        __delay32(2000000);
    }
}

// =========================================================
// FUNKCJA GŁÓWNA
// =========================================================
int main(void){
    // Konfiguracja sprzętu
    AD1PCFG = 0xFFFF; // Piny jako cyfrowe I/O
    TRISA = 0x0000;   // Cały port A (wszystkie 8 diod LED) jako wyjścia
    
    LCD_Initialize();

    // Zaczynamy od programu nr 1
    int active_program = 1; 

    // Główna pętla sterująca maszyną stanów
    while(1) {
        switch(active_program) {
            case 1: active_program = prog1(); break;
            case 2: active_program = prog2(); break;
            case 3: active_program = prog3(); break;
            case 4: active_program = prog4(); break;
            case 5: active_program = prog5(); break;
            case 6: active_program = prog6(); break;
            default: active_program = 1; break; // Zabezpieczenie
        }
    }
    
    return 0;
}
