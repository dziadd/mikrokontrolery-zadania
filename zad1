#include <xc.h>
#include <libpic30.h>
#include <stdbool.h>    
#include <stdint.h>     
#include "buttons.h"
#include "lcd.h" 

//8-bitowy licznik binarny w górę
int prog1(void) {
    unsigned char count = 0; 
    
    LCD_ClearScreen();
    LCD_PutString("P1: BIN W GORE", 14);
    
    // Zabezpieczenie drgań styków - czekamy na puszczenie przycisków
    while(BUTTON_IsPressed(BUTTON_S6) || BUTTON_IsPressed(BUTTON_S3)) { __delay32(10000); }

    while(1) {
        if (BUTTON_IsPressed(BUTTON_S6)) return 2;
        if (BUTTON_IsPressed(BUTTON_S3)) return 6;6

        LATA = count; 
        count++;      
        
        __delay32(2000000);
    }
}

//8-bitowy licznik binarny w dół
int prog2(void) {
    unsigned char count = 255; 
    
    LCD_ClearScreen();
    LCD_PutString("P2: BIN W DOL", 13);
    
    while(BUTTON_IsPressed(BUTTON_S6) || BUTTON_IsPressed(BUTTON_S3)) { __delay32(10000); }

    while(1) {
        if (BUTTON_IsPressed(BUTTON_S6)) return 3;
        if (BUTTON_IsPressed(BUTTON_S3)) return 1;

        LATA = count;
        count--; // Dekrementacja
        
        __delay32(2000000); 
    }
}

//8-bitowy licznik kod Graya w górę
int prog3(void) {
    unsigned char count = 0;
    
    LCD_ClearScreen();
    LCD_PutString("P3: GRAY W GORE", 15);
    
    while(BUTTON_IsPressed(BUTTON_S6) || BUTTON_IsPressed(BUTTON_S3)) { __delay32(10000); }

    while(1) {
        if (BUTTON_IsPressed(BUTTON_S6)) return 4;
        if (BUTTON_IsPressed(BUTTON_S3)) return 2;

        //Konwersja kodu binarnego na kod Graya:
        unsigned char grayValue = count ^ (count >> 1);
        LATA = grayValue;
        
        count++; 
        __delay32(2000000);
    }
}

//8-bitowy licznik kod Graya w dół
int prog4(void) {
    unsigned char count = 255;
    
    LCD_ClearScreen();
    LCD_PutString("P4: GRAY W DOL", 14);
    
    while(BUTTON_IsPressed(BUTTON_S6) || BUTTON_IsPressed(BUTTON_S3)) { __delay32(10000); }

    while(1) {
        if (BUTTON_IsPressed(BUTTON_S6)) return 5;
        if (BUTTON_IsPressed(BUTTON_S3)) return 3;

        unsigned char grayValue = count ^ (count >> 1);
        LATA = grayValue;
        
        count--; 
        __delay32(2000000);
    }
}

//2x4 bitowy licznik w kodzie BCD w górę (0...99)
int prog5(void) {
    char tens = 0; // dziesiątki
    char units = 0; // jedności
    
    LCD_ClearScreen();
    LCD_PutString("P5: BCD W GORE", 14);
    
    while(BUTTON_IsPressed(BUTTON_S6) || BUTTON_IsPressed(BUTTON_S3)) { __delay32(10000); }

    while(1) {
        if (BUTTON_IsPressed(BUTTON_S6)) return 6;
        if (BUTTON_IsPressed(BUTTON_S3)) return 4;

        //Składanie dwóch cyfr na jednym porcie
        LATA = (tens << 4) | units;

        units++;
        if (units > 9) {
            units = 0;
            tens++;
            if (tens > 9) {
                tens = 0; //wyzerowanie po dojściu do 99
            }
        }
        __delay32(2000000);
    }
}

//2x4 bitowy licznik w kodzie BCD w dół (99...0)
int prog6(void) {
    char tens = 9;
    char units = 9;
    
    LCD_ClearScreen();
    LCD_PutString("P6: BCD W DOL", 13);
    
    while(BUTTON_IsPressed(BUTTON_S6) || BUTTON_IsPressed(BUTTON_S3)) { __delay32(10000); }

    while(1) {
        if (BUTTON_IsPressed(BUTTON_S6)) return 1;
        if (BUTTON_IsPressed(BUTTON_S3)) return 5;

        LATA = (tens << 4) | units;

        units--;
        if (units < 0) {
            units = 9;
            tens--;
            if (tens < 0) {
                tens = 9;
            }
        }
        __delay32(2000000);
    }
}


int main(void){
    //conf
    AD1PCFG = 0xFFFF; 
    TRISA = 0x0000;   
    
    LCD_Initialize();

    //start od programu nr 1
    int active_program = 1; 

    //glowna petla sterujaca przelaczaniem programow
    while(1) {
        switch(active_program) {
            case 1: active_program = prog1(); break;
            case 2: active_program = prog2(); break;
            case 3: active_program = prog3(); break;
            case 4: active_program = prog4(); break;
            case 5: active_program = prog5(); break;
            case 6: active_program = prog6(); break;
            default: active_program = 1; break; 
        }
    }
    
    return 0;
}
